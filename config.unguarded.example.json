{
  "server": {
    "name": "mcpfs",
    "version": "0.4.0",
    "transport": "stdio",
    "auth": {
      "mode": "none"
    }
  },
  "roots": [
    {
      "id": "project",
      "path": "/path/to/project",
      "mode": "read_write",
      "include": [
        "**/*"
      ],
      "exclude": [
        "**/.git/**",
        "**/.idea/**",
        "**/.vscode/**",
        "**/node_modules/**",
        "**/vendor/**",
        "**/tmp/**",
        "**/.env",
        "**/.env.*",
        "**/*secret*",
        "**/*credential*",
        "**/*.pem",
        "**/*.key",
        "**/*.p12",
        "**/*.sqlite",
        "**/*.db"
      ],
      "use_gitignore": true,
      "max_file_bytes": 262144
    }
  ],
  "commands": {
    "mode": "unguarded",
    "defaults": {
      "timeout_seconds": 60,
      "max_output_bytes": 65536
    }
  }
}
