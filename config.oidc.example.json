{
  "server": {
    "name": "mcpfs",
    "version": "0.4.0",
    "transport": "http",
    "addr": "127.0.0.1:8080",
    "path": "/mcp",
    "auth": {
      "mode": "oidc",
      "issuer": "https://accounts.google.com",
      "audience": "mcpfs",
      "jwks_url": "https://www.googleapis.com/oauth2/v3/certs",
      "allowed_emails": [
        "you@example.com"
      ]
    }
  },
  "roots": [
    {
      "id": "mcpfs",
      "path": ".",
      "mode": "read",
      "include": [
        "**/*.go",
        "**/*.md",
        "**/*.mod",
        "**/*.sum",
        "**/*.json",
        "**/*.yaml",
        "**/*.yml"
      ],
      "exclude": [
        "**/.git/**",
        "**/.idea/**",
        "**/.vscode/**",
        "**/node_modules/**",
        "**/vendor/**",
        "**/tmp/**",
        "**/.env",
        "**/.env.*",
        "**/*secret*",
        "**/*credential*",
        "**/*.pem",
        "**/*.key",
        "**/*.p12",
        "**/*.sqlite",
        "**/*.db"
      ],
      "use_gitignore": true,
      "max_file_bytes": 262144
    }
  ],
  "commands": {
    "mode": "disabled"
  }
}
